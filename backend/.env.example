# =============================================================================
# MateMaTeX 2.0 — Backend Environment Variables
# =============================================================================
# Copy to .env and fill in your values.

# Database (PostgreSQL — optional; leave empty to run without DB features)
# Example (Neon, Railway Postgres, local):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
# Many hosted poolers need port 6543; asyncpg sets statement_cache_size=0 when
# the hostname contains "pooler".
DATABASE_URL=

# Optional: if set, clients must send X-API-Key: <value> or Authorization: Bearer <value>
MATE_API_KEY=

# LLM API keys (at least one required)
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
# Google model id (see https://ai.google.dev/gemini-api/docs/models)
DEFAULT_MODEL=gemini-3-flash-preview
PRIMARY_MODEL=gemini-3-flash-preview
FALLBACK_MODEL=gemini-3-flash-preview
