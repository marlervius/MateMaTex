# MateMaTeX 2.0 — Frontend Environment Variables
# Copy to .env.local for local development.
# In Vercel dashboard, set as Environment Variables.

NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only on Vercel: same value as backend MATE_API_KEY. Used by /api/generate/.../stream proxy.
# Do NOT prefix with NEXT_PUBLIC_.
# MATE_API_KEY=

# Optional: internal URL for the proxy (defaults to NEXT_PUBLIC_API_URL)
# BACKEND_INTERNAL_URL=http://localhost:8000

# Default: SSE goes through same-origin /api/generate/[jobId]/stream (recommended).
# Set to "false" to connect EventSource directly to NEXT_PUBLIC_API_URL (needs NEXT_PUBLIC_MATE_API_KEY for auth).
# NEXT_PUBLIC_STREAM_PROXY=false

# Optional: exposed in browser — only if you cannot use the SSE proxy (less secure).
# NEXT_PUBLIC_MATE_API_KEY=
